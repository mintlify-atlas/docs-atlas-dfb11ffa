  "keyFeatures": [
    "Product and batch inventory tracking with expiration management",
    "Stock movement recording (entries, exits, adjustments)",
    "Customer and supplier stakeholder management",
    "Real-time inventory valuation and rotation reports",
    "Role-based access control (Admin, Manager, Consultant)",
    "Comprehensive audit logging for all system actions",
    "Dashboard with key inventory metrics and alerts",
    "Price history tracking and bulk price updates"
  ],
